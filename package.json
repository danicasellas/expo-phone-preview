{
  "name": "expo-phone-preview",
  "version": "0.1.1",
  "description": "A tiny browser phone frame for previewing Expo Web apps from localhost.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.cjs",
    "desktop": "electron .",
    "dist:win": "electron-builder --win --dir",
    "dist:win:installer": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --universal --publish never",
    "test": "node --test test/*.test.mjs"
  },
  "keywords": [
    "expo",
    "react-native",
    "preview",
    "phone",
    "localhost"
  ],
  "author": "danicasellas",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.danicasellas.expophonepreview",
    "productName": "Expo Phone Preview",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "README.md",
      "LICENSE",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
